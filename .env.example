# =====================================================================
#  Everest v9.0 — Environment Variables
# =====================================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to git — it's in .gitignore.

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- Reddit API (Sentiment Engine) ---
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET

# --- NewsAPI (News Intelligence) ---
NEWSAPI_KEY=YOUR_NEWSAPI_KEY

# =====================================================================
#  v9.0: LLM INTELLIGENCE LAYER
# =====================================================================

# --- Groq API (Primary LLM — Free Tier) ---
# Sign up at https://console.groq.com (no credit card required)
# Create an API key and paste it below
GROQ_API_KEY=YOUR_GROQ_API_KEY
